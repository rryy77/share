{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [{ "src": "public/**", "use": "@vercel/static" }],
  "routes": [
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/view", "dest": "/public/view.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
